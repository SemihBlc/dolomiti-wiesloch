---
import Layout from "../layouts/Layout.astro";
import { d } from "../data";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const img = (src: string) => src.startsWith("http") ? src : `${base}/${src}`;
const fonts =
  "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;0,9..144,900;1,9..144,500&family=Inter:wght@400;500;600;700;800;900&display=swap";
const site = Astro.site?.href.replace(/\/$/, "") ?? "https://semihblc.github.io";
const businessSchema = {
  "@type": "IceCreamShop",
  "@id": `${site}${base}/#business`,
  name: `${d.name} Wiesloch`,
  image: [`${site}${base}/fotos/hero.jpg`, `${site}${base}/fotos/nasenschild.jpg`],
  telephone: d.telHref.replace("tel:", ""),
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hauptstraße 72",
    postalCode: "69168",
    addressLocality: "Wiesloch",
    addressCountry: "DE",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.6",
    reviewCount: d.reviews,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "09:00",
      closes: "22:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Sunday",
      opens: "10:00",
      closes: "22:00",
    },
  ],
};
const faqSchema = {
  "@type": "FAQPage",
  "@id": `${site}${base}/#faq`,
  mainEntity: d.faq.map(([question, answer]) => ({
    "@type": "Question",
    name: question,
    acceptedAnswer: {
      "@type": "Answer",
      text: answer,
    },
  })),
};
const schema = {
  "@context": "https://schema.org",
  "@graph": [businessSchema, faqSchema],
};
---

<Layout
  title={`${d.name} Wiesloch — Eis, Caffè & Bistro an der Hauptstraße`}
  description="Eiscafé Dolomiti in Wiesloch: hausgemachtes Gelato, Spaghettieis, Waffeln, Caffè und italienische Bistroküche direkt in der Hauptstraße."
  fonts={fonts}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <main class="dolomiti-page" id="top">
    <header class="site-header">
      <div class="header-inner">
        <a href="#top" class="brand" aria-label="Dolomiti Startseite">
          <span class="brand-mark">D</span>
          <span>
            <span class="brand-name">Dolomiti</span>
            <span class="brand-sub">Eiscafé · Bistro · Wiesloch</span>
          </span>
        </a>
        <nav class="nav" aria-label="Navigation">
          <a href="#fotos">Fotos</a>
          <a href="#besuch">Besuch</a>
          <a href="#angebot">Karte</a>
          <a href="#faq">Fragen</a>
          <a href="#kontakt">Kontakt</a>
        </nav>
        <a href={d.telHref} class="call-pill">Anrufen</a>
      </div>
    </header>

    <section class="hero-section">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="overline">Hauptstraße 72 · seitlich Sonne, vorne Eis</p>
          <h1>
            Erst Sonne.
            Dann Spaghettieis.
            <span>Mitten in Wiesloch.</span>
          </h1>
          <p class="lead">
            Zwischen Markt, Schule und Feierabend: Kinder mit Eis auf der Hand,
            Eltern mit Caffè, später Pizza oder Pasta — und immer dieser kurze Moment an der Hauptstraße.
          </p>

          <div class="hero-actions" aria-label="Schnelle Aktionen">
            <a href={d.mapsUrl} target="_blank" rel="noopener" class="primary-action">Route zur Theke</a>
            <a href={d.telHref} class="secondary-action">Kurz anrufen</a>
          </div>

          <div class="counter-note" data-open-badge>
            <span class="note-label">Heute</span>
            <strong data-today-hours>Mo–Sa 09:00–22:00 · So ab 10:00</strong>
            <span data-open-state>Zeiten können je nach Wetter und Saison wechseln.</span>
          </div>
        </div>

        <div class="hero-collage" aria-label="Dolomiti Collage">
          <figure class="photo-frame main-photo">
            <img src={img("fotos/hero.jpg")} width="1600" height="900" alt="Spaghettieis und Cappuccino draußen beim Eiscafé Dolomiti" fetchpriority="high" decoding="async" />
            <figcaption>Spaghettieis draußen</figcaption>
          </figure>
          <figure class="photo-frame sign-photo">
            <img src={img("fotos/nasenschild.jpg")} width="1200" height="960" alt="Dolomiti Nasenschild in der Wieslocher Hauptstraße" loading="lazy" decoding="async" />
            <figcaption>Hauptstraße 72</figcaption>
          </figure>
          <div class="gelato-ticket">
            <span>kurz stoppen</span>
            <strong>Eis · Caffè · Bistro</strong>
            <small>{d.rating} ★ · {d.reviews} Bewertungen</small>
          </div>
        </div>
      </div>
    </section>

    <section class="flavour-strip" aria-label="Gelato-Sorten">
      <div class="flavour-track">
        {[...d.sorten, ...d.sorten].map(([name, c]) => (
          <span class="flavour" style={`--dot:${c}`}><i></i>{name}</span>
        ))}
      </div>
    </section>

    <section id="fotos" class="photo-section" data-reveal>
      <div class="section-heading split-heading">
        <div>
          <p class="overline">Nicht Stockfoto. Dolomiti.</p>
          <h2>So sieht die Pause wirklich aus.</h2>
        </div>
        <p>
          Keine glatten Symbolbilder: echte Theke, echte Terrasse, echte Hauptstraße.
          Genau diese kleinen Szenen machen Dolomiti wiedererkennbar.
        </p>
      </div>

      <div class="story-gallery" data-carousel>
        <button class="gallery-arrow prev" type="button" data-prev aria-label="Vorheriges Foto">‹</button>
        <div class="gallery-track" data-track>
          {d.bilder.map((foto, i) => (
            <figure class="gallery-slide" data-slide>
              <img src={img(foto.src)} width="1400" height="1000" alt={foto.alt} loading={i === 0 ? "eager" : "lazy"} decoding="async" />
              <figcaption>{foto.label}</figcaption>
            </figure>
          ))}
        </div>
        <button class="gallery-arrow next" type="button" data-next aria-label="Nächstes Foto">›</button>
        <div class="gallery-dots" aria-label="Foto auswählen">
          {d.bilder.map((_foto, i) => (
            <button type="button" data-dot={i} aria-label={`Foto ${i + 1} anzeigen`} class={i === 0 ? "is-active" : ""}></button>
          ))}
        </div>
      </div>
    </section>

    <section id="besuch" class="visit-section" data-reveal>
      <div class="section-heading">
        <p class="overline">Drei kleine Szenen</p>
        <h2>Zwischen Schule, Markt und Feierabend.</h2>
      </div>
      <div class="scene-grid">
        {d.momente.map(([title, text], i) => (
          <article class={`scene-card scene-${i + 1}`}>
            <span>0{i + 1}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="team-section" data-reveal>
      <figure class="team-photo">
        <img src={img("fotos/terrasse-original.jpg")} width="1400" height="984" alt="Außenbereich vom Eiscafé Dolomiti in der Hauptstraße" loading="lazy" decoding="async" />
      </figure>
      <div class="team-copy">
        <p class="overline">Manuel & Team</p>
        <h2>Keine sterile Kette. Ein Ort mit Wiedererkennung.</h2>
        <p>
          Dolomiti lebt von Dingen, die man wiedererkennt: Terrasse, Nasenschild, Theke,
          bekannte Gesichter und der kurze Stopp mitten in der Stadt.
        </p>
        <div class="signature">Manuel &amp; Team</div>
      </div>
    </section>

    <section id="angebot" class="menu-section" data-reveal>
      <div class="menu-board">
        <div class="menu-intro">
          <p class="overline">Eis & Bistro</p>
          <h2>Was steht auf dem kleinen Dolomiti-Zettel?</h2>
          <p>Auszug aus dem Angebot — ohne erfundene Preise, Sorten und Gerichte können saisonal wechseln.</p>
        </div>
        <div class="menu-list">
          {d.karte.map(([t, desc]) => (
            <div class="menu-row">
              <strong>{t}</strong>
              <span>{desc}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="hours-section" data-reveal>
      <div class="hours-card">
        <p class="overline">Öffnungszeiten</p>
        <h2>Heute kurz vorbeikommen?</h2>
        <div class="hours-list">
          {d.oeffnungszeiten.map(([tag, zeit]) => (
            <div><span>{tag}</span><strong>{zeit}</strong></div>
          ))}
        </div>
        <p>Zeiten können wetter- und saisonbedingt abweichen — kurz anrufen ist am sichersten.</p>
        <a href={d.telHref}>{d.tel}</a>
      </div>
      <div class="rating-card">
        <span>★★★★★</span>
        <strong>{d.rating}</strong>
        <p>aus {d.reviews} Google-Bewertungen</p>
      </div>
    </section>

    <section id="faq" class="faq-section" data-reveal>
      <div class="section-heading split-heading">
        <div>
          <p class="overline">Kurz beantwortet</p>
          <h2>Vor dem Besuch.</h2>
        </div>
        <p>Die Antworten bleiben bewusst praktisch: draußen sitzen, Waffeln, Zeiten, kurz anrufen.</p>
      </div>
      <div class="faq-list">
        {d.faq.map(([question, answer], i) => (
          <details open={i === 0}>
            <summary>{question}<span>+</span></summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </section>

    <footer id="kontakt" class="contact-section">
      <div>
        <p class="overline">Dolomiti Wiesloch</p>
        <h2>Komm vorbei.</h2>
        <dl>
          <div><dt>Adresse</dt><dd>{d.adresse}</dd></div>
          <div><dt>Telefon</dt><dd><a href={d.telHref}>{d.tel}</a></dd></div>
        </dl>
        <div class="footer-actions">
          <a href={d.mapsUrl} target="_blank" rel="noopener">Route öffnen</a>
          <a href={d.telHref}>Anrufen</a>
        </div>
      </div>
      <div class="footer-note">
        <strong>Dolomiti</strong>
        <span>{d.adresse} · Inhaber {d.inhaber}</span>
        <small>NURAC Konzeptvorschau · Fotos, Zeiten, Impressum &amp; Datenschutz vor Livegang final abstimmen</small>
      </div>
    </footer>

    <div class="mobile-cta" aria-label="Schnelle Aktionen mobil">
      <a href={d.telHref}>Anrufen</a>
      <a href={d.mapsUrl} target="_blank" rel="noopener">Route</a>
    </div>
  </main>

  <style>
    :root {
      --ink: #243026;
      --muted: #665f50;
      --cream: #fff5df;
      --paper: #fffaf0;
      --gelato: #f1dfb9;
      --terracotta: #bb4e24;
      --terracotta-dark: #963617;
      --mint: #6aa6a0;
      --blue: #61aeca;
      --green: #295f4c;
      --shadow: 0 28px 70px -42px rgba(36, 48, 38, .75);
    }

    .dolomiti-page {
      min-height: 100svh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 9% 10%, rgba(97,174,202,.18) 0 11rem, transparent 11.2rem),
        radial-gradient(circle at 90% 4%, rgba(255,213,104,.38) 0 13rem, transparent 13.2rem),
        linear-gradient(90deg, rgba(36,48,38,.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(36,48,38,.035) 1px, transparent 1px),
        var(--cream);
      background-size: auto, auto, 42px 42px, 42px 42px, auto;
      color: var(--ink);
      font-family: Inter, system-ui, sans-serif;
      padding-bottom: 4.4rem;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 40;
      border-bottom: 1px solid rgba(36,48,38,.14);
      background: rgba(255,245,223,.88);
      backdrop-filter: blur(18px);
    }

    .site-header::after {
      content: "";
      display: block;
      height: .55rem;
      background: repeating-linear-gradient(90deg, var(--terracotta) 0 2.2rem, #fff1d1 2.2rem 4.4rem, var(--green) 4.4rem 6.6rem, #fff1d1 6.6rem 8.8rem);
      opacity: .9;
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 72rem;
      margin: 0 auto;
      padding: .8rem 1.25rem;
      gap: 1rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .75rem;
      color: inherit;
      text-decoration: none;
    }

    .brand-mark {
      display: grid;
      width: 2.4rem;
      height: 2.4rem;
      place-items: center;
      border: 2px solid rgba(36,48,38,.16);
      border-radius: 50%;
      background: var(--paper);
      color: var(--terracotta);
      font-family: Fraunces, Georgia, serif;
      font-weight: 900;
      box-shadow: 0 12px 26px -20px rgba(0,0,0,.5);
    }

    .brand-name {
      display: block;
      font-family: Fraunces, Georgia, serif;
      font-size: 1.55rem;
      font-weight: 900;
      line-height: 1;
      letter-spacing: -.03em;
    }

    .brand-sub {
      display: block;
      margin-top: .1rem;
      font-size: .68rem;
      font-weight: 800;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .nav {
      display: flex;
      gap: 1.5rem;
      font-size: .88rem;
      font-weight: 800;
    }

    .nav a,
    .call-pill,
    .hero-actions a,
    .footer-actions a,
    .hours-card a {
      color: inherit;
      text-decoration: none;
    }

    .nav a:hover { color: var(--terracotta); }

    .call-pill,
    .primary-action,
    .secondary-action,
    .footer-actions a,
    .mobile-cta a {
      border-radius: 999px;
      font-weight: 900;
    }

    .call-pill,
    .primary-action,
    .footer-actions a:first-child,
    .mobile-cta a:first-child {
      background: var(--terracotta);
      color: white;
      box-shadow: 0 18px 34px -20px rgba(187,78,36,.9);
    }

    .call-pill { padding: .7rem 1rem; font-size: .88rem; }

    .hero-section { border-bottom: 1px solid rgba(36,48,38,.13); }

    .hero-grid {
      display: grid;
      max-width: 72rem;
      margin: 0 auto;
      grid-template-columns: minmax(0, .92fr) minmax(20rem, 1.08fr);
      align-items: center;
      gap: 3.5rem;
      padding: clamp(3.4rem, 6vw, 6.8rem) 1.25rem clamp(3rem, 6vw, 5.5rem);
    }

    .overline {
      margin: 0;
      color: var(--terracotta);
      font-size: .78rem;
      font-weight: 900;
      letter-spacing: .24em;
      text-transform: uppercase;
    }

    .hero-copy h1,
    .section-heading h2,
    .team-copy h2,
    .menu-intro h2,
    .hours-card h2,
    .contact-section h2 {
      font-family: Fraunces, Georgia, serif;
      letter-spacing: -.055em;
    }

    .hero-copy h1 {
      max-width: 10ch;
      margin: 1.05rem 0 0;
      font-size: clamp(3.8rem, 8.4vw, 7.2rem);
      font-weight: 900;
      line-height: .78;
      text-wrap: balance;
    }

    .hero-copy h1 span {
      display: block;
      color: var(--blue);
      font-style: italic;
    }

    .lead {
      max-width: 36rem;
      margin: 1.6rem 0 0;
      color: var(--muted);
      font-size: clamp(1.05rem, 1.6vw, 1.3rem);
      line-height: 1.72;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .8rem;
      margin-top: 1.8rem;
    }

    .hero-actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3.35rem;
      padding: 0 1.6rem;
      transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    }

    .primary-action:hover,
    .call-pill:hover,
    .footer-actions a:first-child:hover { background: var(--terracotta-dark); transform: translateY(-1px); }

    .secondary-action,
    .footer-actions a:last-child,
    .mobile-cta a:last-child {
      border: 1px solid rgba(36,48,38,.18);
      background: rgba(255,250,240,.76);
      color: var(--ink);
    }

    .secondary-action:hover { transform: translateY(-1px); border-color: rgba(187,78,36,.45); }

    .counter-note {
      position: relative;
      display: grid;
      max-width: 31rem;
      margin-top: 1.6rem;
      gap: .35rem;
      border: 1px dashed rgba(36,48,38,.24);
      border-radius: 1.1rem;
      background: rgba(255,250,240,.72);
      padding: 1rem 1.15rem;
      box-shadow: 0 20px 45px -35px rgba(36,48,38,.8);
      transform: rotate(-.6deg);
    }

    .counter-note::before {
      content: "";
      position: absolute;
      inset: -.55rem auto auto 2rem;
      width: 5rem;
      height: 1rem;
      background: rgba(255,214,107,.55);
      transform: rotate(2deg);
    }

    .note-label {
      color: var(--terracotta);
      font-size: .72rem;
      font-weight: 900;
      letter-spacing: .2em;
      text-transform: uppercase;
    }

    .counter-note strong { font-size: 1.05rem; }
    .counter-note span:last-child { color: var(--muted); font-size: .9rem; line-height: 1.45; }

    .hero-collage {
      position: relative;
      min-height: clamp(34rem, 48vw, 42rem);
    }

    .photo-frame {
      position: absolute;
      margin: 0;
      overflow: hidden;
      border: .7rem solid var(--paper);
      background: var(--paper);
      box-shadow: var(--shadow);
    }

    .photo-frame img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .photo-frame figcaption,
    .gallery-slide figcaption {
      position: absolute;
      left: 1rem;
      bottom: 1rem;
      z-index: 2;
      border-radius: 999px;
      background: rgba(255,250,240,.94);
      padding: .55rem .9rem;
      color: var(--terracotta);
      font-size: .88rem;
      font-weight: 900;
      box-shadow: 0 15px 34px -24px rgba(0,0,0,.7);
    }

    .main-photo {
      inset: 2.2rem 0 auto 2rem;
      width: min(38rem, 85%);
      height: clamp(23rem, 32vw, 30rem);
      border-radius: 2.1rem;
      transform: rotate(1.3deg);
    }

    .sign-photo {
      right: .4rem;
      bottom: 2.6rem;
      width: min(16rem, 38%);
      height: 18.5rem;
      border-radius: 1.4rem;
      transform: rotate(-5deg);
      z-index: 2;
    }

    .gelato-ticket {
      position: absolute;
      left: 0;
      bottom: 1.2rem;
      z-index: 3;
      display: grid;
      gap: .25rem;
      width: min(17rem, 42%);
      border: 1px solid rgba(36,48,38,.18);
      border-radius: 1.2rem;
      background: var(--green);
      color: #fff8ea;
      padding: 1.1rem;
      box-shadow: 0 30px 60px -36px rgba(0,0,0,.8);
      transform: rotate(3deg);
    }

    .gelato-ticket span { color: #ffdba3; font-size: .75rem; font-weight: 900; letter-spacing: .16em; text-transform: uppercase; }
    .gelato-ticket strong { font-family: Fraunces, Georgia, serif; font-size: 1.55rem; line-height: 1; }
    .gelato-ticket small { color: rgba(255,248,234,.76); }

    .flavour-strip {
      border-block: 1px solid rgba(36,48,38,.13);
      background: var(--gelato);
      overflow: hidden;
      padding: .8rem 0;
    }

    .flavour-track {
      display: flex;
      width: max-content;
      gap: 1.45rem;
      animation: marquee 38s linear infinite;
    }

    .flavour {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      color: var(--ink);
      font-family: Fraunces, Georgia, serif;
      font-size: 1.55rem;
      font-weight: 650;
      white-space: nowrap;
    }

    .flavour::after { content: "◆"; color: #d5a073; font-size: 1rem; }
    .flavour i { width: .75rem; height: .75rem; border-radius: 50%; background: var(--dot); box-shadow: inset 0 0 0 1px rgba(36,48,38,.14); }

    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    .photo-section,
    .visit-section,
    .menu-section,
    .faq-section,
    .hours-section,
    .team-section {
      max-width: 72rem;
      margin: 0 auto;
      padding: clamp(3.5rem, 6vw, 5.5rem) 1.25rem;
    }

    .section-heading {
      max-width: 42rem;
      margin-bottom: 2rem;
    }

    .split-heading {
      display: grid;
      max-width: none;
      grid-template-columns: minmax(0, .95fr) minmax(16rem, .75fr);
      align-items: end;
      gap: 2rem;
    }

    .section-heading h2,
    .team-copy h2,
    .menu-intro h2,
    .hours-card h2,
    .contact-section h2 {
      margin: .65rem 0 0;
      font-size: clamp(2.5rem, 5vw, 4.6rem);
      font-weight: 900;
      line-height: .9;
      text-wrap: balance;
    }

    .section-heading p:last-child,
    .team-copy p,
    .menu-intro p,
    .hours-card p,
    .contact-section dd,
    .footer-note {
      color: var(--muted);
      line-height: 1.7;
    }

    .story-gallery {
      position: relative;
      border-radius: 2.2rem;
      background: rgba(255,250,240,.62);
      box-shadow: var(--shadow);
    }

    .gallery-track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      border: .55rem solid var(--paper);
      border-radius: 2.2rem;
      scrollbar-width: none;
    }

    .gallery-track::-webkit-scrollbar { display: none; }

    .gallery-slide {
      position: relative;
      flex: 0 0 100%;
      height: clamp(24rem, 56vw, 38rem);
      margin: 0;
      scroll-snap-align: start;
      overflow: hidden;
      background: var(--gelato);
    }

    .gallery-slide::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,.27));
      pointer-events: none;
    }

    .gallery-slide img { width: 100%; height: 100%; object-fit: cover; }

    .gallery-arrow {
      position: absolute;
      top: 50%;
      z-index: 3;
      display: grid;
      width: 3rem;
      height: 3rem;
      place-items: center;
      border: 0;
      border-radius: 50%;
      background: rgba(255,250,240,.94);
      color: var(--ink);
      font-size: 2.2rem;
      line-height: 1;
      transform: translateY(-50%);
      box-shadow: 0 18px 36px -24px rgba(0,0,0,.75);
      cursor: pointer;
    }

    .gallery-arrow.prev { left: 1.15rem; }
    .gallery-arrow.next { right: 1.15rem; }

    .gallery-dots {
      display: flex;
      justify-content: center;
      gap: .45rem;
      padding: 1rem 0 0;
    }

    .gallery-dots button {
      width: .62rem;
      height: .62rem;
      border: 0;
      border-radius: 999px;
      background: rgba(36,48,38,.22);
      cursor: pointer;
      transition: width .18s ease, background .18s ease;
    }

    .gallery-dots button.is-active { width: 1.7rem; background: var(--terracotta); }

    .scene-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.1rem;
    }

    .scene-card {
      position: relative;
      min-height: 15rem;
      border: 1px solid rgba(36,48,38,.14);
      background: var(--paper);
      padding: 1.35rem;
      box-shadow: 0 24px 48px -38px rgba(36,48,38,.9);
    }

    .scene-card::before {
      content: "";
      position: absolute;
      inset: -.6rem 2rem auto;
      height: 1rem;
      background: rgba(255,214,107,.55);
      transform: rotate(-2deg);
    }

    .scene-card:nth-child(2) { transform: rotate(1.2deg); }
    .scene-card:nth-child(3) { transform: rotate(-.8deg); }
    .scene-card span { color: var(--terracotta); font-weight: 900; letter-spacing: .16em; }
    .scene-card h3 { margin: 2.2rem 0 .8rem; font-family: Fraunces, Georgia, serif; font-size: 2.15rem; line-height: .95; }
    .scene-card p { margin: 0; color: var(--muted); line-height: 1.65; }

    .team-section {
      display: grid;
      grid-template-columns: .95fr 1.05fr;
      align-items: center;
      gap: 2rem;
    }

    .team-photo {
      margin: 0;
      overflow: hidden;
      border: .65rem solid var(--paper);
      border-radius: 2rem;
      box-shadow: var(--shadow);
      transform: rotate(-1.3deg);
    }

    .team-photo img { display: block; width: 100%; aspect-ratio: 1 / .82; object-fit: cover; }

    .team-copy {
      border-left: .45rem solid var(--terracotta);
      background: rgba(255,250,240,.64);
      padding: 2rem;
    }

    .signature { margin-top: 1.4rem; color: var(--terracotta); font-family: Fraunces, Georgia, serif; font-size: 2.1rem; font-style: italic; font-weight: 650; }

    .menu-board {
      display: grid;
      grid-template-columns: .7fr 1.3fr;
      gap: 2rem;
      border-radius: 2rem;
      background:
        linear-gradient(135deg, rgba(255,255,255,.04), transparent 32%),
        var(--green);
      color: #fff8ea;
      padding: clamp(1.3rem, 4vw, 3rem);
      box-shadow: var(--shadow);
    }

    .menu-board .overline { color: #ffdba3; }
    .menu-intro p { color: rgba(255,248,234,.72); }

    .menu-list { display: grid; gap: .4rem; }

    .menu-row {
      display: grid;
      grid-template-columns: 13rem minmax(0,1fr);
      gap: 1.2rem;
      border-bottom: 1px dashed rgba(255,248,234,.28);
      padding: .95rem 0;
    }

    .menu-row strong { font-family: Fraunces, Georgia, serif; font-size: 1.35rem; line-height: 1.05; color: #ffdba3; }
    .menu-row span { color: rgba(255,248,234,.82); line-height: 1.55; }

    .hours-section {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(15rem, .55fr);
      gap: 1.2rem;
      align-items: stretch;
    }

    .hours-card,
    .rating-card,
    .faq-list details {
      border: 1px solid rgba(36,48,38,.13);
      border-radius: 1.6rem;
      background: rgba(255,250,240,.7);
      box-shadow: 0 24px 50px -42px rgba(36,48,38,.8);
    }

    .hours-card { padding: 2rem; }
    .hours-list { display: grid; gap: .7rem; margin: 1.4rem 0; }
    .hours-list div { display: flex; justify-content: space-between; gap: 1rem; border-radius: 1rem; background: var(--paper); padding: .9rem 1rem; }
    .hours-list span { color: var(--muted); font-weight: 800; }
    .hours-list strong { color: var(--terracotta); }
    .hours-card a { display: inline-flex; margin-top: .5rem; color: var(--green); font-weight: 900; }

    .rating-card {
      display: grid;
      place-items: center;
      align-content: center;
      padding: 2rem;
      text-align: center;
      background: var(--gelato);
    }

    .rating-card span { color: #c58d2d; letter-spacing: .12em; }
    .rating-card strong { font-family: Fraunces, Georgia, serif; font-size: 5.4rem; line-height: .9; }
    .rating-card p { color: var(--muted); }

    .faq-list { display: grid; gap: .8rem; }
    .faq-list details { padding: 1.15rem 1.25rem; }
    .faq-list summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; cursor: pointer; list-style: none; font-weight: 900; }
    .faq-list summary::-webkit-details-marker { display: none; }
    .faq-list summary span { display: grid; width: 2rem; height: 2rem; place-items: center; border-radius: 50%; background: var(--cream); color: var(--terracotta); transition: transform .18s ease; }
    .faq-list details[open] summary span { transform: rotate(45deg); }
    .faq-list p { margin: 1rem 0 0; color: var(--muted); line-height: 1.7; }

    .contact-section {
      display: grid;
      grid-template-columns: 1fr .9fr;
      gap: 2rem;
      background: var(--green);
      color: #fff8ea;
      padding: clamp(3.5rem, 7vw, 5rem) max(1.25rem, calc((100vw - 72rem) / 2));
    }

    .contact-section .overline { color: #ffdba3; }
    .contact-section dl { display: grid; gap: 1rem; margin: 2rem 0 0; }
    .contact-section dt { color: #ffdba3; font-size: .76rem; font-weight: 900; letter-spacing: .2em; text-transform: uppercase; }
    .contact-section dd { margin: .25rem 0 0; color: rgba(255,248,234,.9); font-size: 1.15rem; }
    .contact-section a { color: inherit; }
    .footer-actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.6rem; }
    .footer-actions a { display: inline-flex; padding: .9rem 1.25rem; }
    .footer-note { display: grid; align-content: end; gap: .55rem; color: rgba(255,248,234,.62); }
    .footer-note strong { color: #fff8ea; font-family: Fraunces, Georgia, serif; font-size: 2.3rem; }
    .footer-note small { color: rgba(255,248,234,.38); }

    .mobile-cta {
      position: fixed;
      inset: auto 0 0;
      z-index: 50;
      display: none;
      gap: .5rem;
      border-top: 1px solid rgba(36,48,38,.13);
      background: rgba(255,245,223,.95);
      padding: .65rem;
      backdrop-filter: blur(14px);
    }

    .mobile-cta a { flex: 1; padding: .9rem .75rem; text-align: center; text-decoration: none; }

    .js [data-reveal] { opacity: 0; transform: translateY(18px); transition: opacity .62s ease, transform .62s ease; }
    .js [data-reveal].in { opacity: 1; transform: none; }

    @media (max-width: 900px) {
      .nav { display: none; }
      .hero-grid,
      .split-heading,
      .team-section,
      .menu-board,
      .hours-section,
      .contact-section {
        grid-template-columns: 1fr;
      }
      .hero-grid { gap: 2rem; padding-top: 2.4rem; }
      .hero-copy h1 { max-width: 9ch; }
      .hero-collage { min-height: 30rem; }
      .main-photo { left: 0; width: 88%; height: 21.5rem; }
      .sign-photo { width: 11rem; height: 13rem; bottom: 1.8rem; }
      .gelato-ticket { width: 12.5rem; }
      .scene-grid { grid-template-columns: 1fr; }
      .scene-card:nth-child(n) { transform: none; }
      .menu-row { grid-template-columns: 1fr; gap: .3rem; }
      .mobile-cta { display: flex; }
    }

    @media (max-width: 560px) {
      .brand-sub { display: none; }
      .brand-name { font-size: 1.35rem; }
      .call-pill { display: none; }
      .hero-copy h1 { font-size: clamp(3.55rem, 18vw, 5rem); }
      .lead { font-size: 1rem; line-height: 1.62; }
      .hero-actions { display: grid; grid-template-columns: 1fr 1fr; }
      .hero-actions a { min-height: 3rem; padding-inline: .8rem; font-size: .9rem; }
      .hero-collage { min-height: 25rem; }
      .main-photo { top: 1rem; height: 18rem; border-width: .45rem; border-radius: 1.35rem; }
      .sign-photo { right: 0; width: 8.6rem; height: 10.2rem; border-width: .4rem; }
      .gelato-ticket { left: .2rem; width: 11.2rem; padding: .85rem; }
      .gelato-ticket strong { font-size: 1.25rem; }
      .gallery-slide { height: 21rem; }
      .gallery-arrow { display: none; }
      .flavour { font-size: 1.25rem; }
      .section-heading h2,
      .team-copy h2,
      .menu-intro h2,
      .hours-card h2,
      .contact-section h2 { font-size: clamp(2.25rem, 12vw, 3.2rem); }
      .team-copy { padding: 1.35rem; }
      .photo-section,
      .visit-section,
      .menu-section,
      .faq-section,
      .hours-section,
      .team-section { padding-block: 3.4rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .flavour-track { animation: none; }
      .gallery-track { scroll-behavior: auto; }
      .js [data-reveal] { opacity: 1; transform: none; transition: none; }
    }
  </style>

  <script>
    document.documentElement.classList.add("js");

    document.querySelectorAll("[data-carousel]").forEach((carousel) => {
      const track = carousel.querySelector("[data-track]");
      const slides = Array.from(carousel.querySelectorAll("[data-slide]"));
      const dots = Array.from(carousel.querySelectorAll("[data-dot]"));
      const prev = carousel.querySelector("[data-prev]");
      const next = carousel.querySelector("[data-next]");
      if (!track || slides.length === 0) return;
      let raf = 0;
      const currentIndex = () => Math.max(0, Math.min(slides.length - 1, Math.round(track.scrollLeft / track.clientWidth)));
      const setActive = () => {
        const active = currentIndex();
        dots.forEach((dot, i) => dot.classList.toggle("is-active", i === active));
      };
      const go = (index) => {
        const target = (index + slides.length) % slides.length;
        track.scrollTo({ left: target * track.clientWidth, behavior: "smooth" });
      };
      prev?.addEventListener("click", () => go(currentIndex() - 1));
      next?.addEventListener("click", () => go(currentIndex() + 1));
      dots.forEach((dot, i) => dot.addEventListener("click", () => go(i)));
      track.addEventListener("scroll", () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(setActive);
      }, { passive: true });
      window.addEventListener("resize", setActive, { passive: true });
      setActive();
    });

    const setOpeningCue = () => {
      const badges = document.querySelectorAll("[data-open-badge]");
      if (!badges.length) return;
      const berlinNow = new Date(new Date().toLocaleString("en-US", { timeZone: "Europe/Berlin" }));
      const day = berlinNow.getDay();
      const minutes = berlinNow.getHours() * 60 + berlinNow.getMinutes();
      const sunday = day === 0;
      const opens = sunday ? 10 * 60 : 9 * 60;
      const closes = 22 * 60;
      const label = sunday ? "Heute: 10:00–22:00" : "Heute: 09:00–22:00";
      const openNow = minutes >= opens && minutes < closes;
      const beforeOpen = minutes < opens;
      const state = openNow
        ? "Wahrscheinlich gerade geöffnet — bei Wetter/Saison kurz anrufen."
        : beforeOpen
          ? `Öffnet voraussichtlich ab ${sunday ? "10:00" : "09:00"} — kurz anrufen, wenn du sicher gehen willst.`
          : "Für heute wahrscheinlich vorbei — morgen wieder Sommerzeiten. Kurz anrufen, wenn du sicher gehen willst.";
      document.querySelectorAll("[data-today-hours]").forEach((el) => { el.textContent = label; });
      document.querySelectorAll("[data-open-state]").forEach((el) => { el.textContent = state; });
      badges.forEach((badge) => {
        badge.classList.toggle("is-open", openNow);
        badge.classList.toggle("is-closed", !openNow);
      });
    };
    setOpeningCue();

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in");
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
  </script>
</Layout>
