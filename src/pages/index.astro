---
import Layout from "../layouts/Layout.astro";
import { d } from "../data";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const fonts =
  "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,900;1,9..144,500;1,9..144,600&family=Inter:wght@400;500;600;700&display=swap";
// Jagged Dolomiten-Kammlinie (wiederkehrendes Markenmotiv)
const ridge =
  "M0,200 L0,128 L120,52 L210,118 L320,34 L450,120 L560,58 L690,128 L820,40 L960,116 L1080,62 L1200,104 L1200,200 Z";
---

<Layout title={`${d.name} Wiesloch — Hausgemachtes Eis & italienisches Bistro`} fonts={fonts}>
  <main class="min-h-svh overflow-x-hidden bg-[#f2ebdd] text-[#23291f] antialiased [font-family:Inter,sans-serif] pb-20 sm:pb-0">
    <!-- Header -->
    <header class="sticky top-0 z-30 border-b border-[#23291f]/10 bg-[#f2ebdd]/85 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3.5">
        <span class="flex items-center gap-2">
          <svg viewBox="0 0 28 18" class="h-4 w-6 text-[#2f5141]" fill="currentColor" aria-hidden="true"><path d="M0 18 L8 4 L13 11 L18 2 L28 18 Z"/></svg>
          <span class="ds text-2xl leading-none font-semibold tracking-tight">Dolomiti</span>
        </span>
        <a href={d.telHref} class="rounded-full bg-[#a8481f] px-4 py-2 text-sm font-semibold text-[#f2ebdd] transition hover:bg-[#8d3a16]">Anrufen</a>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative isolate overflow-hidden">
      <!-- Berg-Kammlinie als dezenter Backdrop -->
      <svg viewBox="0 0 1200 200" preserveAspectRatio="none" aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-64 w-full text-[#2f5141]/8"><path d={ridge} fill="currentColor"/></svg>

      <div class="hero-stagger mx-auto max-w-5xl px-5 pt-12 pb-14 text-center sm:pt-16">
        <p class="text-xs font-semibold tracking-[0.28em] text-[#a8481f] uppercase">Eiscafé &amp; Bistro · Wiesloch</p>
        <h1 class="mt-5">
          <span class="ds block text-lg font-medium tracking-[0.4em] text-[#2f5141] uppercase">Eiscafé</span>
          <span class="glow-text ds block text-7xl leading-[0.92] font-black tracking-tight sm:text-9xl">Dolomiti</span>
        </h1>
        <p class="mx-auto mt-7 max-w-xl text-lg leading-relaxed text-[#5b5345]">
          Hausgemachtes Gelato, <span class="ds font-semibold italic text-[#a8481f]">Spaghettieis</span> und italienische Küche — Eis und Bistro unter einem Dach, mitten an der Hauptstraße.
        </p>

        <div class="mt-7 inline-flex items-center gap-2.5 rounded-full border border-[#2f5141]/25 bg-[#2f5141]/10 px-4 py-2 text-sm font-medium text-[#2f5141]">
          <span class="size-2 rounded-full bg-[#2f5141]"></span>
          <span>Eiscafé-Saison · täglich geöffnet</span>
        </div>

        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <a href={d.telHref} class="rounded-full bg-[#a8481f] px-8 py-4 font-semibold text-[#f2ebdd] shadow-sm transition hover:-translate-y-0.5 hover:bg-[#8d3a16]">Einfach anrufen</a>
          <a href={d.mapsUrl} target="_blank" rel="noopener" class="rounded-full border border-[#23291f]/20 px-8 py-4 font-semibold transition hover:-translate-y-0.5 hover:border-[#a8481f] hover:text-[#a8481f]">Route öffnen</a>
        </div>

        <p class="mt-7 text-sm text-[#5b5345]">
          <span class="text-[#c6943a]">★★★★★</span> <strong class="font-semibold text-[#23291f]">{d.rating}</strong> · {d.reviews} Google-Bewertungen
        </p>

        <figure class="relative mx-auto mt-14 max-w-3xl overflow-hidden rounded-[2rem] shadow-[0_24px_60px_-18px_rgba(35,41,31,0.5)] ring-1 ring-[#23291f]/10">
          <img src={`${base}/fotos/hero.jpg`} width="1600" height="900" alt="Spaghettieis mit Cappuccino auf der Terrasse vom Eiscafé Dolomiti" class="kenburns aspect-[16/9] w-full object-cover" fetchpriority="high" />
          <figcaption class="absolute bottom-4 left-4 rounded-full bg-[#f2ebdd]/95 px-5 py-1.5 text-sm font-semibold text-[#a8481f] shadow ring-1 ring-[#23291f]/10">Spaghettieis · frisch gemacht</figcaption>
        </figure>
      </div>
    </section>

    <!-- Gelato-Farbleiste -->
    <div class="border-y border-[#23291f]/10 bg-[#e8dcc4] py-4">
      <div class="marquee">
        <div class="marquee-track">
          {[...d.sorten, ...d.sorten].map(([name, c]) => (
            <span class="ds inline-flex items-center gap-2.5 text-2xl font-semibold text-[#23291f]">
              <span class="size-3 rounded-full ring-1 ring-[#23291f]/10" style={`background:${c}`}></span>{name}
              <span class="px-3 text-[#a8481f]/40">◆</span>
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Über / Manuel -->
    <section data-reveal class="mx-auto max-w-4xl px-5 py-16 text-center">
      <p class="text-xs font-semibold tracking-[0.22em] text-[#a8481f] uppercase">Bei uns am Tresen</p>
      <h2 class="ds mt-4 text-4xl font-semibold sm:text-5xl">Eis machen wir mit Geduld.</h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[#5b5345]">
        Hausgemachtes Gelato, ein Teller Pasta oder eine Pizza, dazu ein echter Espresso — bei
        <span class="font-semibold text-[#23291f]"> Manuel Morgado Morais</span> bekommt man beides an einem Ort.
        Kommt vorbei, nehmt euch Zeit und genießt ein Stück Italien mitten in Wiesloch.
      </p>
      <p class="ds mt-5 text-3xl italic text-[#a8481f]">Manuel &amp; Team</p>
    </section>

    <!-- Eis & Bistro Karte -->
    <section data-reveal class="border-t border-[#23291f]/10 bg-[#e8dcc4]">
      <div class="mx-auto max-w-5xl px-5 py-16">
        <p class="text-xs font-semibold tracking-[0.22em] text-[#a8481f] uppercase">Eis &amp; Bistro</p>
        <h2 class="ds mt-3 text-4xl font-semibold sm:text-5xl">Was bei uns über die Theke geht</h2>
        <p class="mt-3 max-w-2xl text-[#5b5345]">Vom Eisbecher bis zur Pizza — Eiscafé und italienische Küche unter einem Dach.</p>
        <div class="mt-10 grid gap-x-12 gap-y-1 sm:grid-cols-2">
          {d.karte.map(([t, desc]) => (
            <div class="flex items-baseline gap-4 border-b border-dashed border-[#23291f]/15 py-4">
              <span class="ds shrink-0 text-xl font-semibold text-[#2f5141]">{t}</span>
              <span class="text-sm leading-snug text-[#5b5345]">{desc}</span>
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm text-[#9a917f]">Auszug aus dem Angebot · Sorten, Gerichte &amp; Preise variieren saisonal</p>
      </div>
    </section>

    <!-- Spezialitäten -->
    <section data-reveal class="mx-auto max-w-5xl px-5 py-16">
      <p class="text-xs font-semibold tracking-[0.22em] text-[#a8481f] uppercase">Warum Dolomiti</p>
      <h2 class="ds mt-3 text-4xl font-semibold sm:text-5xl">Klein, aber unser Ding</h2>
      <div class="mt-9 grid gap-4 sm:grid-cols-2">
        {d.spezial.map(([t, dd]) => (
          <article class="rounded-2xl border border-[#23291f]/10 bg-[#f2ebdd] p-6 transition hover:-translate-y-1 hover:border-[#a8481f]/40">
            <h3 class="ds text-2xl font-semibold text-[#2f5141]">{t}</h3>
            <p class="mt-2 leading-relaxed text-[#5b5345]">{dd}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Öffnungszeiten + Bewertung -->
    <section data-reveal class="border-t border-[#23291f]/10 bg-[#e8dcc4]">
      <div class="mx-auto grid max-w-5xl items-stretch gap-8 px-5 py-16 sm:grid-cols-2">
        <div class="flex flex-col">
          <p class="text-xs font-semibold tracking-[0.22em] text-[#a8481f] uppercase">Öffnungszeiten</p>
          <h2 class="ds mt-3 text-3xl font-semibold">Im Sommer täglich.</h2>
          <p class="mt-5 leading-relaxed text-[#5b5345]">
            Eiscafé-Saison — die genauen Zeiten stimmen wir mit dem Wirt final ab und tragen sie hier ein.
            In der Zwischenzeit: kurz anrufen, dann weißt du es sicher.
          </p>
          <a href={d.telHref} class="mt-6 inline-flex w-fit items-center gap-2 rounded-full border border-[#2f5141]/30 px-5 py-2.5 text-sm font-semibold text-[#2f5141] transition hover:bg-[#2f5141]/10">
            <span class="size-2 rounded-full bg-[#2f5141]"></span> {d.tel}
          </a>
        </div>
        <div class="flex flex-col justify-center rounded-[1.5rem] bg-[#f2ebdd] p-8 text-center ring-1 ring-[#23291f]/8">
          <div class="text-[#c6943a]">★★★★★</div>
          <div class="ds mt-2 text-6xl font-black">{d.rating}</div>
          <p class="mt-1 text-[#5b5345]">aus {d.reviews} Google-Bewertungen</p>
        </div>
      </div>
    </section>

    <!-- Kontakt -->
    <section class="relative isolate overflow-hidden bg-[#23291f] text-[#f2ebdd]">
      <svg viewBox="0 0 1200 200" preserveAspectRatio="none" aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 -z-0 h-40 w-full text-[#2f5141]/35"><path d={ridge} fill="currentColor"/></svg>
      <div class="relative mx-auto grid max-w-5xl gap-8 px-5 py-16 sm:grid-cols-2">
        <div>
          <h2 class="ds text-4xl font-semibold">Komm vorbei.</h2>
          <dl class="mt-7 space-y-4 text-lg">
            <div><dt class="text-xs tracking-[0.2em] text-[#d98a6a] uppercase">Adresse</dt><dd class="mt-1">{d.adresse}</dd></div>
            <div><dt class="text-xs tracking-[0.2em] text-[#d98a6a] uppercase">Telefon</dt><dd class="mt-1"><a href={d.telHref} class="hover:text-[#e9a87d]">{d.tel}</a></dd></div>
          </dl>
          <a href={d.mapsUrl} target="_blank" rel="noopener" class="mt-7 inline-block rounded-full bg-[#a8481f] px-7 py-3.5 font-semibold transition hover:-translate-y-0.5 hover:bg-[#c25a2a]">Route öffnen</a>
        </div>
        <div class="rounded-[1.5rem] bg-[#f2ebdd]/5 p-7 ring-1 ring-[#f2ebdd]/10">
          <p class="text-xs tracking-[0.2em] text-[#d98a6a] uppercase">Eis &amp; Bistro</p>
          <p class="mt-4 leading-relaxed text-[#cdc6b6]">
            Gelato, Spaghettieis und warme Küche — mitten in Wiesloch, mit Plätzen draußen.
            Erst ein Teller Pasta, dann der Eisbecher: alles an einem Ort.
          </p>
        </div>
      </div>
      <div class="relative flex flex-col items-center gap-2 pb-9">
        <svg viewBox="0 0 28 18" class="h-5 w-8 text-[#d98a6a]" fill="currentColor" aria-hidden="true"><path d="M0 18 L8 4 L13 11 L18 2 L28 18 Z"/></svg>
        <p class="ds text-2xl font-semibold">Dolomiti</p>
        <p class="text-center text-xs text-[#f2ebdd]/45">{d.adresse} · Inhaber {d.inhaber}</p>
        <p class="text-center text-xs text-[#f2ebdd]/35">Seiten-Entwurf von NURAC — noch nicht live</p>
      </div>
    </section>

    <!-- Sticky CTA (mobile) -->
    <div class="fixed inset-x-0 bottom-0 z-40 flex gap-2 border-t border-[#23291f]/10 bg-[#f2ebdd]/95 p-2.5 backdrop-blur sm:hidden">
      <a href={d.telHref} class="flex-1 rounded-full bg-[#a8481f] py-3 text-center font-semibold text-[#f2ebdd]">Anrufen</a>
      <a href={d.mapsUrl} target="_blank" rel="noopener" class="flex-1 rounded-full border border-[#23291f]/20 py-3 text-center font-semibold">Route</a>
    </div>
  </main>

  <style>
    .ds { font-family: "Fraunces", Georgia, serif; }
    .glow-text {
      background-image: linear-gradient(100deg, #2f5141 0%, #a8481f 52%, #d98a6a 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .kenburns { will-change: transform; animation: kenburns 24s ease-in-out infinite alternate; }
    @keyframes kenburns { from { transform: scale(1.02); } to { transform: scale(1.08); } }
    .marquee { overflow: hidden; }
    .marquee-track { display: flex; width: max-content; gap: 0; animation: marquee 32s linear infinite; }
    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    [data-reveal] { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
    [data-reveal].in { opacity: 1; transform: none; }
    .hero-stagger > * { animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
    .hero-stagger > *:nth-child(1) { animation-delay: 0.05s; }
    .hero-stagger > *:nth-child(2) { animation-delay: 0.14s; }
    .hero-stagger > *:nth-child(3) { animation-delay: 0.24s; }
    .hero-stagger > *:nth-child(4) { animation-delay: 0.34s; }
    .hero-stagger > *:nth-child(5) { animation-delay: 0.44s; }
    .hero-stagger > *:nth-child(6) { animation-delay: 0.54s; }
    .hero-stagger > *:nth-child(7) { animation-delay: 0.66s; }
    @keyframes rise { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
    @media (prefers-reduced-motion: reduce) {
      .marquee-track, .kenburns { animation: none; }
      [data-reveal] { opacity: 1; transform: none; transition: none; }
      .hero-stagger > * { animation: none; }
    }
  </style>

  <script>
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
  </script>
</Layout>
